<!--
# Seek - 2d Steering

A planet follows the cursor and a `<SeekAgent2d>` ship steers toward it via the `{SteerTarget::Entity($planet)}` reference.

    beet --features=winit --main=examples/spatial/seek.bsx
-->
<Scene2d>
	<CrateCheck features="winit"/>
	<AppWindow/>
	<Camera2d/>
	<SpaceScene/>
	<Sprite2d src="spaceship_pack/planet_6.png" x=200. bx:ref="planet" {FollowCursor2d}/>
	<SeekAgent2d src="spaceship_pack/ship_2.png" {SteerTarget::Entity($planet)}/>
</Scene2d>
