<!--
# Inverse Kinematics - Procedural Arm

A robot arm glb with `{IkSpawner}` solves its joints toward the keyboard-movable `<IkTarget>` sphere.

    beet --main=examples/spatial/inverse_kinematics.bsx
-->
<Scene3d>
	<CrateCheck features="winit"/>
	<AppWindow/>
	<Camera3dLookAt x=0. y=7. z=7./>
	<Lighting3d/>
	<Ground3d/>
	<IkTarget bx:ref="target"/>
	<WorldScene src="robot-arm/robot-arm.glb#Scene0" scale=10. {(IkSpawner, TargetEntity::Other($target))}/>
</Scene3d>
