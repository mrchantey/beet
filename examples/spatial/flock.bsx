<!--
# Flock - Group Steering

`<Flock count=300/>` fills a 2d space scene with boids steered by separate/align/cohere/wander behaviors.

    beet --main=examples/spatial/flock.bsx
-->
<Scene2d>
	<CrateCheck features="winit"/>
	<AppWindow/>
	<Camera2d/>
	<SpaceScene/>
	<Flock count=300/>
</Scene2d>
