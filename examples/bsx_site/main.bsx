<!--
The whole site: a router serving the `routes/` directory, every page wrapped
in the `templates/Layout.bsx` document. The router's middleware and server
attach as component spreads (request logging, `--help`, terminal link
navigation, the layout, and an `HttpServer`), while `<DefaultAppRoutes/>` adds
the default app routes (eg the `/js/reactivity.js` runtime a reactive page
loads) as child routes. There is no `main.rs`: `beet serve` spawns this host and
triggers its server, which the site owns here in markup. The `<PackageConfig/>`
declaration patches the named fields of the resource, creating it from defaults
if absent, so the title and description are set in markup with no compile-time
host config.
-->
<Router {(RequestLogger, HelpHandler, NavigateHandler, BsxLayout{template:"Layout"}, HttpServer{port:8337})}>
	<PackageConfig title="BSX Site" description="A beet site with zero code"/>
	<Theme color={Srgba(Srgba{red:0.5, green:0.2, blue:0.9, alpha:1.0})}/>
	<Styles/>
	<DefaultAppRoutes/>
	<RoutesDir src="routes"/>
</Router>
