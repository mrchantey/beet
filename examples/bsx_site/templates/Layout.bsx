<!DOCTYPE html>
<!--
The document layout wrapping every route: each page's body transcludes into
the <Slot/> inside <main>. <RouteHead> fills the page title/description from
frontmatter (and the default head emits og:site_name from PackageConfig.title),
<RouteSidebar/> collects the route tree into the nav rail, and the footer's @res
binding pulls straight from the PackageConfig resource.
-->
<html lang="en">
	<RouteHead>
		<Preflight/>
		<Reset/>
		<Stylesheet/>
		<ColorSchemeScript/>
		<LiveReloadScript/>
		<ReactivityScript/>
	</RouteHead>
	<body>
		<Header>
			<MenuButton slot="leading"/>
			<a slot="nav" href="/docs">Docs</a>
			<a slot="nav" href="https://github.com/mrchantey/beet">GitHub</a>
		</Header>
		<div class="container">
			<RouteSidebar home=false exclude={["export"]}/>
			<main><Slot/></main>
		</div>
		<Footer>{@res:PackageConfig.description}</Footer>
	</body>
</html>
