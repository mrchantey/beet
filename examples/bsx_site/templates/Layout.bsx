<!DOCTYPE html>
<!--
The document layout wrapping every route: each page's body transcludes into
the <Slot/> inside <main>. <RouteHead> fills the page title/description from
frontmatter, <RouteSidebar/> collects the route tree into the nav rail, and
the @res bindings pull straight from the PackageConfig resource.
-->
<html lang="en">
	<RouteHead>
		<meta property="og:site_name" content=@res:PackageConfig.title/>
		<Preflight/>
		<Reset/>
		<Stylesheet/>
		<ColorSchemeScript/>
		<LiveReloadScript/>
	</RouteHead>
	<body>
		<Header>
			<MenuButton slot="leading"/>
			<a slot="nav" href="/docs">Docs</a>
			<a slot="nav" href="https://github.com/mrchantey/beet">GitHub</a>
		</Header>
		<div class="container">
			<RouteSidebar home=false exclude={["export"]}/>
			<main><Slot/></main>
		</div>
		<Footer>{@res:PackageConfig.description}</Footer>
	</body>
</html>
