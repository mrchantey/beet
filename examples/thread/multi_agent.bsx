<!--
Two agents converse, the whole program in one scene. Run it through the one
binary:

    beet --main=examples/thread/multi_agent.bsx

The behavior is `Repeat[Sequence[agent, agent]]`: two differently-instructed
agents take turns forever, kicked by `{RunThread}` (runs until Ctrl+C). The
transcript renders full-screen with no composer (there is no user turn).
-->
<div>
	<div {Repeat} {RunThread}>
		<div bx:ref="thread" {Thread} {Sequence}>
			<CreateActor name="System" kind="System">
				<CreatePost text="this is a roleplay, keep responses under 50 words."/>
			</CreateActor>
			<CreateActor name="Beet lover" kind="Agent" {ModelStreamer{provider:OpenAi, instructions:"You love beets"}}/>
			<CreateActor name="Beet disliker" kind="Agent" {ModelStreamer{provider:OpenAi, instructions:"You think beets are bad but dont want to hurt feelings"}}/>
		</div>
	</div>
	<ThreadChat>
		<div {ThreadView{thread:$thread}}/>
	</ThreadChat>
</div>
