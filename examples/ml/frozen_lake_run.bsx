	<CrateCheck features="ml"/>
	<AppWindow/>
	<Camera3d {CameraDistance{width:0.77, offset:{x:0., y:0.7, z:0.7}}}/>
	<Lighting3d/>
	<FrozenLake/>
	<FrozenLakeRunAgent/>
</Scene3d>
