// https://zed.dev/docs/configuring-zed#settings-files
{
	// "show_completions_on_input": false,
	// "completions": {
	// 	"words": "disabled"
	// },
	// "show_edit_predictions": false,
	// "snippet_sort_order": "inline",
	// "autosave": "off",
	"lsp": {
		"rust-analyzer": {
			"initialization_options": {
				"cargo": {
					// "target": "wasm32-unknown-unknown",
					"features": "all",
					// "features": [],
					// "allTargets": false,
					// "noDefaultFeatures": true,
					// run check on nightly so `nightly` feature's #![feature(..)] compiles (avoids E0554)
					"extraEnv": { "RUSTUP_TOOLCHAIN": "nightly" },
					// [
					// "all",
					// "tui",
					// "world_serde",
					// "json",
					// "_pretty_curl",
					// "_mini_browser",
					// "http_server",
					// "stack",
					// "server"
					// "client",
					// "launch",
					// "tungstenite"
					// "lambda"
					// "aws"
					// "webdriver",
					// "css",
					// "sim",
					// "bevy_default",
					// "spatial",
					// "examples",
					// "ml",
					// "cuda",
					// "rand"
					// ],
				},
				"completion": {
					"snippets": {
						"custom": {
							"Arc::new": {
								"postfix": "arc",
								"body": ["Arc::new(${receiver})"],
								"requires": "std::sync::Arc",
								"scope": "expr",
							},
							"Some": {
								"postfix": "some",
								"body": ["Some(${receiver})"],
								"scope": "expr",
							},
							"Ok": {
								"postfix": "ok",
								"body": ["Ok(${receiver})"],
								"scope": "expr",
							},
							"Rc::new": {
								"postfix": "rc",
								"body": ["Rc::new(${receiver})"],
								"requires": "std::rc::Rc",
								"scope": "expr",
							},
							"Box::pin": {
								"postfix": "boxpin",
								"body": ["Box::pin(${receiver})"],
								"requires": "std::boxed::Box",
								"scope": "expr",
							},
							"vec!": {
								"postfix": "vec",
								"body": ["vec![${receiver}]"],
								"description": "vec![]",
								"scope": "expr",
							},
						},
					},
				},
			},
		},
	},
	"file_scan_inclusions": [
		// "target",
		".agents/plan*",
		".agents/report*",
		".agents/feedback*",
	],
	"file_scan_exclusions": [
		".cargo",
		".beet",
		".claude",
		// ".gitignore",
		".env.example",
		".github",
		".playwright-cli",
		".vscode",
		"CLAUDE.md",
		"target",
		"rustfmt.toml",
		"CHANGELOG.md",
		"Cargo.lock",
		"**/.git",
		".gitattributes",
		"LICENSE-APACHE.txt",
		"LICENSE-MIT.txt",
		"**/node_modules",
		// "rustc-ice**",
	],
}
