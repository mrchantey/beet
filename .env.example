ANTHROPIC_API_KEY=https://console.anthropic.com/settings/keys
OPENAI_API_KEY=https://platform.openai.com/api-keys
CEREBRAS_API_KEY=https://cloud.cerebras.ai/platform
GITHUB_API_TOKEN=https://github.com/settings/tokens
GEMINI_API_KEY=https://aistudio.google.com/apikey

CLOUDFLARE_ACCOUNT_ID=https://dash.cloudflare.com/login > 'ctrl + k' > "Copy Account ID"
CLOUDFLARE_ZONE_ID=https://dash.cloudflare.com > select your domain > Overview > (right column) API > "Copy" Zone ID
# Account · Account Settings: Read
# Account · Workers Scripts: Edit
# Account · Workers R2 Storage: Edit
# Account · Workers KV Storage: Edit
# Account · Workers Builds Configuration: Edit
# Account · D1: Edit
# Account · Containers: Edit
# Account · Cloudchamber: Edit
# Zone · DNS: Edit
# Zone · Workers Routes: Edit
# Zone · Cache Purge: Edit
# Zone · Cache Rules: Edit
# Zone · Zone Settings: Edit (also covers Spectrum apps, there is no Spectrum permission group)
# Cloudflare Containers need no separate permission: a container deploys through
# Workers Scripts, and its image is pushed to Cloudflare's managed registry (R2-backed,
# auth handled automatically), so the Workers + R2 perms above already cover it.
# (Add Account · API Tokens: Edit only if the deploy mints the R2 token below itself.)
CLOUDFLARE_API_TOKEN=https://dash.cloudflare.com/profile/api-tokens > Create Token > Create Custom Token > Token name: `beet-deploy` > add the permissions listed above > Account Resources = your account, Zone Resources = your zone > Continue To Summary > Create Token > Copy

R2_ACCESS_KEY_ID=https://dash.cloudflare.com > R2 > "API Tokens" > "Manage" > Create Account API Token > Token name: `beet-r2` > Object Read & Write > Create Account API Token > copy "Access Key ID"
R2_SECRET_ACCESS_KEY= ^^^ copy "Secret Access Key"

# beet reads AWS creds explicitly from here (not the global ~/.aws profile). Copy from `aws configure get aws_access_key_id` / `cat ~/.aws/credentials`, or create new keys at the IAM console below
AWS_ACCESS_KEY_ID=https://us-east-1.console.aws.amazon.com/iam/home?region=us-west-2#/users > name > Security Credentials > Access Keys > Create Access Key
AWS_SECRET_ACCESS_KEY=https://us-east-1.console.aws.amazon.com/iam/home?region=us-west-2#/users > name > Security Credentials > Access Keys > Create Access Key
AWS_REGION=us-west-2
AWS_IAM_ROLE=https://us-east-1.console.aws.amazon.com/iam/home?region=us-west-2#/roles
AWS_BEARER_TOKEN_BEDROCK=https://us-east-1.conso·le.aws.amazon.com/bedrock/home?region=us-east-1#/api-keys?tab=long-term
